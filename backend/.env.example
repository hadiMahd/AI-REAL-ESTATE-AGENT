# Model is optional. Defaults to gpt-oss:120b.
OLLAMA_MODEL=

OLLAMA_TIMEOUT=120

# Required for Ollama Cloud API.
OLLAMA_API_KEY=

# Required for production-grade shared cache/rate-limit state.
REDIS_URL=redis://localhost:6379/0

# Optional tuning knobs.
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60
LLM_HEALTH_CACHE_TTL_SECONDS=20
REDIS_KEY_PREFIX=house_price_api
